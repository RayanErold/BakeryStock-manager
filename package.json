    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@clerk/express": "^2.1.15",
    "@clerk/shared": "^4.10.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "serverless-http": "^4.0.0",
    "zod": "catalog:"
  }
}